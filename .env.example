# ---------- Server ----------
PORT=3000
APP_BASE_URL=http://localhost:3000

# ---------- Redis ----------
# ใส่ connection string ของ Redis (เช่น Redis Cloud, Upstash, หรือ local redis-server)
REDIS_URL=redis://127.0.0.1:6379

# ---------- LINE Login ----------
# สร้าง Channel แบบ "LINE Login" ได้ที่ https://developers.line.biz/console/
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CALLBACK_URL=http://localhost:3000/auth/line/callback

# ---------- Security ----------
# ใช้สำหรับเซ็น JWT session cookie และ hash LINE userId -> App_User_ID
# สร้างด้วยคำสั่ง: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string
USER_ID_HASH_SALT=change_this_to_another_long_random_string
